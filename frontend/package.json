    "format": "prettier --check .",
    "test": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3",
    "vue-tsc": "^3.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prettier": "^3.7.3"
  }
}
